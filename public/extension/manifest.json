{
  "manifest_version": 3,
  "name": "Nairi AI Assistant",
  "version": "1.0.0",
  "description": "Quick access to Nairi AI from any webpage - chat, analyze, and create with AI",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.nairi.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["content/content-styles.css"]
    }
  ],
  "side_panel": {
    "default_path": "popup/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
