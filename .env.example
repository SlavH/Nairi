# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# For running migrations (psql / npm run migrate): get from Supabase → Project Settings → Database → Connection string
DATABASE_URL=

# Bypass auth (development): when true, protected pages are accessible without login. Never enable in production.
# For full features (chat, creations, etc.), set BYPASS_USER_ID to an existing auth user's UUID (Supabase Dashboard → Authentication → Users). Otherwise DB inserts may fail.
BYPASS_AUTH=true
# Optional: UUID of a real user in auth.users so bypass mode works like that user (chat, creations, RLS). Copy from Supabase → Auth → Users after signing in once.
# BYPASS_USER_ID=

# Stripe (payments and webhook)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Nairi HF Space – web-grounded chat (SearXNG + 2-pass: PLAN → FINAL). Backend has its own system prompt (Nairi/Наири).
# Base URL only (no /health or /chat). Example: https://slavnairi-nairi-generation.hf.space
NAIRI_HF_BASE_URL=https://slavnairi-nairi-generation.hf.space
# Fallback if NAIRI_HF_BASE_URL not set:
# NAIRI_AI_BASE_URL=

# SearXNG Space – web search for Nairi chat. GET {SEARXNG_BASE_URL}/search?q=...&format=json&language=en
# Example: https://your-searxng-space.hf.space (no trailing slash)
SEARXNG_BASE_URL=https://your-searxng-space.hf.space

# Nairi HF Router – async generation (text, image, video, code, etc.). POST /generate → job_id → poll /status, /result.
# Base URL only (no trailing slash). Example: https://slavnairi-nairi-router.hf.space
NAIRI_ROUTER_BASE_URL=https://slavnairi-nairi-router.hf.space

# Colab-style backend (POST /chat). Used when NAIRI_AI_BASE_URL is not set.
COLAB_AI_BASE_URL=https://your-ngrok-url.ngrok.io
# BITNET_BASE_URL=

# Request timeout (ms). Colab can be slow; 60000 = 60s default. Optional Colab-only override:
# COLAB_REQUEST_TIMEOUT_MS=90000
AI_REQUEST_TIMEOUT=60000
AI_MAX_RETRIES=2

# Web search for builder (layout/structure research for portfolio, landing, etc.)
# Optional: SERPER_API_KEY (serper.dev) or TAVILY_API_KEY (tavily.com)
SERPER_API_KEY=
# TAVILY_API_KEY=

# Replicate (video generation)
REPLICATE_API_TOKEN=


# Rate limiting (production) - when set, use Redis for rate limit store so limits apply across instances
REDIS_URL=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
